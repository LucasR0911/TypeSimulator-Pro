<Window x:Class="TypeSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TypeSimulator - 高级输入模拟器"
        Height="740"
        Width="1080"
        MinHeight="680"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        FontFamily="Microsoft YaHei UI">

    <Window.Resources>
        <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F4F9FF" Offset="0"/>
            <GradientStop Color="#EAF4FF" Offset="0.5"/>
            <GradientStop Color="#F9FCFF" Offset="1"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="PrimaryBrush" Color="#156FD9"/>
        <SolidColorBrush x:Key="PrimaryDeepBrush" Color="#0F4EA4"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#17A673"/>
        <SolidColorBrush x:Key="InkBrush" Color="#23364D"/>
        <SolidColorBrush x:Key="SoftInkBrush" Color="#4A5F79"/>

        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#0E5CB8" Offset="0"/>
            <GradientStop Color="#1A78E0" Offset="0.65"/>
            <GradientStop Color="#1F8AA6" Offset="1"/>
        </LinearGradientBrush>

        <DropShadowEffect x:Key="CardShadowEffect" BlurRadius="18" ShadowDepth="0" Opacity="0.16" Color="#143252"/>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D7E3F2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Effect" Value="{StaticResource CardShadowEffect}"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#D5E2F1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#C8D8ED"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Background" Value="#FCFEFF"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Background" Value="#E8EEF7"/>
            <Setter Property="BorderBrush" Value="#D0DBEA"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.93"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.80"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#E9F2FF"/>
            <Setter Property="Foreground" Value="#2F4C6F"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#CF4E4E"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16" Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Canvas IsHitTestVisible="False" Opacity="0.8">
            <Ellipse Width="260" Height="260" Fill="#1A1A78E0" Canvas.Left="-70" Canvas.Top="-90"/>
            <Ellipse Width="190" Height="190" Fill="#1217A673" Canvas.Right="-40" Canvas.Top="70"/>
            <Ellipse Width="220" Height="220" Fill="#12105FB0" Canvas.Right="140" Canvas.Bottom="-120"/>
        </Canvas>

        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}" CornerRadius="16" Padding="16" Margin="0,0,0,12" Opacity="0">
            <Border.RenderTransform>
                <TranslateTransform Y="12"/>
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.38"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.38"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="TypeSimulator" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="V9 · 人类输入回放增强版" Margin="0,4,0,0" Foreground="#E7F2FF" FontSize="13"/>
                </StackPanel>
                <Border Grid.Column="1" Background="#2AFFFFFF" BorderBrush="#4FFFFFFF" BorderThickness="1" CornerRadius="10" Padding="10,4" VerticalAlignment="Center">
                    <TextBlock Text="Realistic Typing Replay" Foreground="#ECF6FF" FontSize="12" FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3.1*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,8,0" Opacity="0">
                <Border.RenderTransform>
                    <TranslateTransform Y="14"/>
                </Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.40" BeginTime="0:0:0.06"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.40" BeginTime="0:0:0.06"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4,2,4,10">
                        <TextBlock Text="输入文本" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource InkBrush}"/>
                        <TextBlock Text="（支持直接粘贴）" Margin="8,1,0,0" Foreground="{StaticResource SoftInkBrush}" FontSize="12"/>
                    </StackPanel>

                    <TextBox Grid.Row="1" x:Name="InputTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="14"
                             MinHeight="250"
                             BorderBrush="#BFD2EA"
                             Background="#FCFEFF"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button x:Name="PasteButton"
                                Content="粘贴文本"
                                Width="100"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="PasteButton_Click"/>
                        <Button x:Name="ClearButton"
                                Content="清空文本"
                                Width="100"
                                Margin="8,0,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="ClearButton_Click"/>
                    </StackPanel>

                    <TextBlock Grid.Row="3"
                               Text="建议：长文本可开启节奏曲线与疲劳曲线，回放更接近人工输入。"
                               Margin="0,10,2,0"
                               Foreground="#53708F"
                               FontSize="12"/>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="8,0,0,0" Opacity="0">
                <Grid.RenderTransform>
                    <TranslateTransform Y="14"/>
                </Grid.RenderTransform>
                <Grid.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.40" BeginTime="0:0:0.12"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.40" BeginTime="0:0:0.12"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Grid.Triggers>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="模拟打字设置">
                    <Grid Margin="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="打字速度:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider Grid.Row="0" Grid.Column="1" x:Name="SpeedSlider"
                                Minimum="50"
                                Maximum="400"
                                Value="150"
                                TickFrequency="50"
                                IsSnapToTickEnabled="True"
                                ValueChanged="SpeedSlider_ValueChanged"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" x:Name="SpeedValueText"
                                   Text="150 CPM" Width="74" TextAlignment="Right" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="随机延迟:" VerticalAlignment="Center" Margin="0,10,8,0"/>
                        <CheckBox Grid.Row="1" Grid.Column="1" x:Name="RandomDelayCheckBox"
                                  Content="启用随机打字延迟"
                                  Margin="0,10,0,0"
                                  Checked="RandomDelayCheckBox_Changed"
                                  Unchecked="RandomDelayCheckBox_Changed"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="标点发呆停顿:" VerticalAlignment="Center" Margin="0,10,8,0"/>
                        <CheckBox Grid.Row="2" Grid.Column="1" x:Name="PunctuationDazePauseCheckBox"
                                  Content="句号/逗号后额外随机停顿"
                                  Margin="0,10,0,0"
                                  Checked="PunctuationDazePauseCheckBox_Changed"
                                  Unchecked="PunctuationDazePauseCheckBox_Changed"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="停顿时长:" VerticalAlignment="Center" Margin="0,10,8,0"/>
                        <Slider Grid.Row="3" Grid.Column="1" x:Name="PunctuationDazeDelaySlider"
                                Minimum="100"
                                Maximum="3000"
                                Value="900"
                                TickFrequency="100"
                                IsSnapToTickEnabled="True"
                                ValueChanged="PunctuationDazeDelaySlider_ValueChanged"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" x:Name="PunctuationDazeDelayValueText"
                                   Text="900 ms" Width="74" TextAlignment="Right" Margin="0,10,0,0" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="错字模拟:" VerticalAlignment="Center" Margin="0,10,8,0"/>
                        <CheckBox Grid.Row="4" Grid.Column="1" x:Name="TypoSimulationCheckBox"
                                  Content="模拟打错字后退格重打"
                                  Margin="0,10,0,0"
                                  Checked="TypoSimulationCheckBox_Changed"
                                  Unchecked="TypoSimulationCheckBox_Changed"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="错字概率:" VerticalAlignment="Center" Margin="0,10,8,0"/>
                        <Slider Grid.Row="5" Grid.Column="1" x:Name="TypoChanceSlider"
                                Minimum="1"
                                Maximum="90"
                                Value="3"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="TypoChanceSlider_ValueChanged"/>
                        <TextBlock Grid.Row="5" Grid.Column="2" x:Name="TypoChanceValueText"
                                   Text="3%" Width="74" TextAlignment="Right" Margin="0,10,0,0" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="双击概率:" VerticalAlignment="Center" Margin="0,10,8,0"/>
                        <Slider Grid.Row="6" Grid.Column="1" x:Name="DoubleHitChanceSlider"
                                Minimum="0"
                                Maximum="30"
                                Value="4"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="DoubleHitChanceSlider_ValueChanged"/>
                        <TextBlock Grid.Row="6" Grid.Column="2" x:Name="DoubleHitChanceValueText"
                                   Text="4%" Width="74" TextAlignment="Right" Margin="0,10,0,0" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="整词删改概率:" VerticalAlignment="Center" Margin="0,10,8,0"/>
                        <Slider Grid.Row="7" Grid.Column="1" x:Name="WholeWordRewriteChanceSlider"
                                Minimum="0"
                                Maximum="30"
                                Value="5"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="WholeWordRewriteChanceSlider_ValueChanged"/>
                        <TextBlock Grid.Row="7" Grid.Column="2" x:Name="WholeWordRewriteChanceValueText"
                                   Text="5%" Width="74" TextAlignment="Right" Margin="0,10,0,0" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="错字后停顿:" VerticalAlignment="Center" Margin="0,10,8,0"/>
                        <CheckBox Grid.Row="8" Grid.Column="1" x:Name="TypoExtraPauseCheckBox"
                                  Content="启用错字后额外 0.5~1 秒犹豫停顿"
                                  Margin="0,10,0,0"
                                  Checked="TypoExtraPauseCheckBox_Changed"
                                  Unchecked="TypoExtraPauseCheckBox_Changed"/>

                        <TextBlock Grid.Row="9" Grid.Column="0" Text="停顿触发概率:" VerticalAlignment="Center" Margin="0,10,8,0"/>
                        <Slider Grid.Row="9" Grid.Column="1" x:Name="TypoExtraPauseChanceSlider"
                                Minimum="0"
                                Maximum="100"
                                Value="100"
                                TickFrequency="5"
                                IsSnapToTickEnabled="True"
                                ValueChanged="TypoExtraPauseChanceSlider_ValueChanged"/>
                        <TextBlock Grid.Row="9" Grid.Column="2" x:Name="TypoExtraPauseChanceValueText"
                                   Text="100%" Width="74" TextAlignment="Right" Margin="0,10,0,0" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="10" Grid.Column="0" Text="节奏曲线:" VerticalAlignment="Center" Margin="0,10,8,0"/>
                        <CheckBox Grid.Row="10" Grid.Column="1" x:Name="PacingCurveCheckBox"
                                  Content="启用开头慢-中段快-结尾慢"
                                  Margin="0,10,0,0"
                                  Checked="PacingCurveCheckBox_Changed"
                                  Unchecked="PacingCurveCheckBox_Changed"/>

                        <TextBlock Grid.Row="11" Grid.Column="0" Text="节奏强度:" VerticalAlignment="Center" Margin="0,10,8,0"/>
                        <Slider Grid.Row="11" Grid.Column="1" x:Name="PacingCurveStrengthSlider"
                                Minimum="10"
                                Maximum="200"
                                Value="100"
                                TickFrequency="10"
                                IsSnapToTickEnabled="True"
                                ValueChanged="PacingCurveStrengthSlider_ValueChanged"/>
                        <TextBlock Grid.Row="11" Grid.Column="2" x:Name="PacingCurveStrengthValueText"
                                   Text="100%" Width="74" TextAlignment="Right" Margin="0,10,0,0" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="12" Grid.Column="0" Text="疲劳曲线:" VerticalAlignment="Center" Margin="0,10,8,0"/>
                        <CheckBox Grid.Row="12" Grid.Column="1" x:Name="FatigueCurveCheckBox"
                                  Content="启用越打越疲劳的节奏变化"
                                  Margin="0,10,0,0"
                                  Checked="FatigueCurveCheckBox_Changed"
                                  Unchecked="FatigueCurveCheckBox_Changed"/>

                        <TextBlock Grid.Row="13" Grid.Column="0" Text="疲劳强度:" VerticalAlignment="Center" Margin="0,10,8,0"/>
                        <Slider Grid.Row="13" Grid.Column="1" x:Name="FatigueCurveStrengthSlider"
                                Minimum="10"
                                Maximum="200"
                                Value="100"
                                TickFrequency="10"
                                IsSnapToTickEnabled="True"
                                ValueChanged="FatigueCurveStrengthSlider_ValueChanged"/>
                        <TextBlock Grid.Row="13" Grid.Column="2" x:Name="FatigueCurveStrengthValueText"
                                   Text="100%" Width="74" TextAlignment="Right" Margin="0,10,0,0" VerticalAlignment="Center"/>

                        <StackPanel Grid.Row="14" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,12,0,0">
                            <Button x:Name="StartTypingButton"
                                    Content="开始打字"
                                    Width="108"
                                    Click="StartTypingButton_Click"/>
                            <Button x:Name="PauseTypingButton"
                                    Content="暂停"
                                    Width="86"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="PauseTypingButton_Click"
                                    IsEnabled="False"/>
                            <Button x:Name="StopTypingButton"
                                    Content="停止"
                                    Width="86"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Click="StopTypingButton_Click"
                                    IsEnabled="False"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="1" Header="按键映射设置">
                    <Grid Margin="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <CheckBox Grid.Row="0"
                                  x:Name="EnableMappingCheckBox"
                                  Content="启用按键映射功能"
                                  Margin="0,4,0,8"
                                  Checked="EnableMappingCheckBox_Changed"
                                  Unchecked="EnableMappingCheckBox_Changed"/>

                        <TextBlock Grid.Row="1"
                                   Text="顺序循环映射：按文本顺序依次输出字符，可用于演示/回放。"
                                   TextWrapping="Wrap"
                                   Foreground="#496686"
                                   Margin="0,2,0,4"/>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="2" Header="快捷键设置">
                    <Grid Margin="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="启动/暂停打字:" Margin="0,4,10,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TypingShortcutText" Text="Ctrl+Alt+T" Margin="0,4,0,4" Foreground="{StaticResource SoftInkBrush}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="映射暂停/恢复:" Margin="0,4,10,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="MappingShortcutText" Text="F10" Margin="0,4,0,4" Foreground="{StaticResource SoftInkBrush}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="重置程序状态:" Margin="0,4,10,4"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ResetShortcutText" Text="Ctrl+F12" Margin="0,4,0,4" Foreground="{StaticResource SoftInkBrush}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="映射完全禁用:" Margin="0,4,10,4"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="DisableMappingShortcutText" Text="F11" Margin="0,4,0,4" Foreground="{StaticResource SoftInkBrush}"/>

                        <Button Grid.Row="4"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                Content="查看实际可用快捷键"
                                Margin="0,10,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="ShowShortcuts_Click"/>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="3" Header="状态信息" Margin="0">
                    <Grid Margin="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="当前状态:" Margin="0,0,6,0"/>
                            <TextBlock x:Name="StatusText" Text="就绪" Foreground="#1D9A67" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,0,0,8">
                            <ProgressBar x:Name="TypingProgressBar" Minimum="0" Maximum="100" Value="0"/>
                            <TextBlock x:Name="ProgressDetailText" Margin="0,6,0,0" Foreground="#4E6783" FontSize="12" Text="待输入: 0 字符"/>
                        </StackPanel>

                        <TextBox Grid.Row="2"
                                 x:Name="LogTextBox"
                                 IsReadOnly="True"
                                 Background="#F8FBFF"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"/>
                    </Grid>
                </GroupBox>
            </Grid>
        </Grid>

        <StatusBar Grid.Row="2" Background="#E7EEF8" BorderBrush="#D2DEEF" BorderThickness="1" Margin="0,12,0,0" Padding="4,1">
            <StatusBarItem>
                <TextBlock x:Name="AppStatusText" Text="程序已准备就绪" Foreground="#28415E"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="KeyPressStatusText" Text="按键状态: 监听中" Foreground="#28415E"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="VersionText" Text="v9.0.0" Foreground="#28415E"/>
            </StatusBarItem>
        </StatusBar>

        <Border Grid.Row="1"
                x:Name="ShortcutInfoPanel"
                Visibility="Collapsed"
                Panel.ZIndex="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="24"
                Padding="18"
                Background="#FFFFFF"
                BorderBrush="#1A78E0"
                BorderThickness="1"
                CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.24" Color="#2B4461"/>
            </Border.Effect>
            <Grid MinWidth="380">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource InkBrush}">当前可用快捷键</TextBlock>

                <StackPanel Grid.Row="1" Margin="4,0">
                    <TextBlock x:Name="TypingShortcutInfoText" Margin="0,4">打字功能切换: Ctrl+Alt+T</TextBlock>
                    <TextBlock x:Name="MappingShortcutInfoText" Margin="0,4">映射功能切换: Ctrl+Shift+M</TextBlock>
                    <TextBlock x:Name="ResetShortcutInfoText" Margin="0,4">重置应用: Ctrl+Alt+R</TextBlock>
                    <TextBlock x:Name="DisableMappingShortcutInfoText" Margin="0,4">映射完全禁用: F11</TextBlock>
                </StackPanel>

                <Button Grid.Row="2"
                        Content="关闭"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0"
                        Width="88"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="CloseShortcutInfo_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
